{
  "name": "wmsomie",
  "version": "1.0.0",
  "description": "WMS com Node.js + MongoDB integrado com Omie",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "cd ui && npm run build && cd .. && node server.js",
    "dev": "nodemon server.js",
    "dev:all": "node start-dev.js",
    "install:all": "npm install && cd ui && npm install",
    "stop": "node stop.js",
    "seed": "node scripts/seed.js",
    "seed:more": "node scripts/generate-more-data.js",
    "cleanup": "node scripts/cleanup-database.js"
  },
  "keywords": [
    "wms",
    "logistica",
    "estoque",
    "omie"
  ],
  "author": "your-name",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.19.2",
    "mongoose": "^8.3.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
